//@version=5
strategy("Nifty Options Algo Strategy", overlay=true, default_qty_type=strategy.fixed, default_qty_value=1)

// Inputs
emaFast = input.int(9, "EMA Fast")
emaSlow = input.int(21, "EMA Slow")
rsiPeriod = input.int(14, "RSI Period")
rsiUpper = input.int(55, "RSI Upper Threshold")
rsiLower = input.int(45, "RSI Lower Threshold")
slPercent = input.float(20.0, "Stop Loss %") / 100

// Indicators
ema9 = ta.ema(close, emaFast)
ema21 = ta.ema(close, emaSlow)
rsi = ta.rsi(close, rsiPeriod)
vwapValue = ta.vwap(hlc3)

// Plot indicators
plot(ema9, "EMA 9", color=color.green, linewidth=2)
plot(ema21, "EMA 21", color=color.red, linewidth=2)
plot(vwapValue, "VWAP", color=color.orange, style=plot.style_circles)

// Trading Hours in IST (use exchange timezone)
// For NSE charts, hour/minute are already in IST
istHour = hour(time, "Asia/Kolkata")
istMinute = minute(time, "Asia/Kolkata")
currentMin = istHour * 60 + istMinute

// 9:45 AM = 585 min, 3:00 PM = 900 min
inTradingHours = currentMin >= 585 and currentMin <= 900
isSquareOffTime = currentMin >= 900 and currentMin <= 930
noNewEntry = currentMin >= 885  // No new entries after 2:45 PM

// === BUY CALL (Long) Conditions ===
bullishCrossover = ta.crossover(ema9, ema21) and rsi > rsiUpper
bullishMomentum = ema9 > ema21 and rsi > rsiUpper and close > vwapValue
bullishPullback = ema9 > ema21 and ta.crossover(close, vwapValue) and rsi > 50
buyCallSignal = (bullishCrossover or bullishMomentum or bullishPullback) and inTradingHours and not noNewEntry

// === BUY PUT (Short) Conditions ===
bearishCrossover = ta.crossunder(ema9, ema21) and rsi < rsiLower
bearishMomentum = ema9 < ema21 and rsi < rsiLower and close < vwapValue
bearishPullback = ema9 < ema21 and ta.crossunder(close, vwapValue) and rsi < 50
buyPutSignal = (bearishCrossover or bearishMomentum or bearishPullback) and inTradingHours and not noNewEntry

// === Strategy Execution ===
if buyCallSignal and strategy.position_size == 0
    strategy.entry("BUY_CALL", strategy.long)

if buyPutSignal and strategy.position_size == 0
    strategy.entry("BUY_PUT", strategy.short)

// Stop Loss
if strategy.position_size > 0
    strategy.exit("SL_CALL", "BUY_CALL", stop=strategy.position_avg_price * (1 - slPercent))

if strategy.position_size < 0
    strategy.exit("SL_PUT", "BUY_PUT", stop=strategy.position_avg_price * (1 + slPercent))

// Square-off at 3:15 PM IST
if isSquareOffTime and strategy.position_size != 0
    strategy.close_all("SQUARE_OFF")

// === Visual Signals ===
plotshape(buyCallSignal and strategy.position_size == 0, "BUY CALL", shape.triangleup, location.belowbar, color.green, size=size.small)
plotshape(buyPutSignal and strategy.position_size == 0, "BUY PUT", shape.triangledown, location.abovebar, color.red, size=size.small)
bgcolor(strategy.position_size > 0 ? color.new(color.green, 90) : strategy.position_size < 0 ? color.new(color.red, 90) : na)

// RSI shown in separate panel below (not on main chart)
// To see RSI, add RSI indicator separately from TradingView indicators menu
